@page "/reptiles"
@inject IReptileService ReptileService
@rendermode InteractiveAuto

<PageTitle>Reptiles</PageTitle>

<div class="page-header">
    <div>
        <h2 class="page-title"><i class="bi bi-bug"></i> My Reptiles</h2>
        <p class="page-subtitle">Manage your reptile collection</p>
    </div>
    <a href="/reptiles/create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add Reptile
    </a>
</div>

@if (Reptiles is null)
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="bi bi-hourglass-split"></i>
        </div>
        <h3>Loading...</h3>
    </div>
}
else if (!Reptiles.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">
            <i class="bi bi-bug"></i>
        </div>
        <h3>No reptiles yet</h3>
        <p>Add your first reptile to get started tracking feedings, sheds, and more.</p>
        <a href="/reptiles/create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add Your First Reptile
        </a>
    </div>
}
else
{
    <div class="table-card">
        <table class="reptile-table">
            <thead>
            <tr>
                <th>Name</th>
                <th>Species</th>
                <th>Morph</th>
                <th>Sex</th>
                <th>Date of Birth</th>
                <th>Age</th>
                <th>Weight (g)</th>
                <th>Length (cm)</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var reptile in Reptiles)
            {
                <tr>
                    <td class="reptile-name">@reptile.Name</td>
                    <td>@reptile.Species</td>
                    <td>@(reptile.Morph is { Length: > 0 } ? reptile.Morph : "—")</td>
                    <td>@(reptile.Sex ?? "—")</td>
                    <td>@(reptile.DateOfBirth?.ToString("MMM d, yyyy") ?? "—")</td>
                    <td>@(reptile.Age.HasValue ? $"{CalculateAge(reptile.Age.Value)}" : "—")</td>
                    <td>@(reptile.LatestGrowth?.WeightGrams?.ToString("0.#") ?? "—")</td>
                    <td>@(reptile.LatestGrowth?.LengthCm?.ToString("0.#") ?? "—")</td>
                    <td class="table-actions">
                        <button class="btn-icon" @onclick="() => ShowDetailsModal(reptile)" title="View">
                            <i class="bi bi-eye"></i>
                        </button>
                        <a href="/reptiles/@reptile.ReptileId/edit" class="btn-icon" title="Edit">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <button class="btn-icon btn-icon-danger" @onclick="() => ShowDeleteModal(reptile)"
                                title="Delete">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

<ReptileDeleteModalComponent @ref="_deleteModal" Reptile="_selectedReptile" OnDeleted="RefreshListAsync"/>
<ReptileDetailsModalComponent @ref="_detailsModal" Reptile="_selectedReptile"/>

<Toasts class="p-3" Messages="messages" AutoHide="true" Delay="6000" Placement="ToastsPlacement.TopRight"/>


@code {
    List<ReptileResponse> Reptiles { get; set; }
    private ReptileResponse? _selectedReptile;
    private ReptileDeleteModalComponent _deleteModal = default!;
    private ReptileDetailsModalComponent _detailsModal = default!;
    readonly List<ToastMessage> messages = new();

    protected override async Task OnInitializedAsync()
    {
        Reptiles = await ReptileService.GetAllAsync();
    }

    private async Task ShowDetailsModal(ReptileResponse reptile)
    {
        _selectedReptile = reptile;
        await _detailsModal.ShowAsync();
    }

    private async Task ShowDeleteModal(ReptileResponse reptile)
    {
        _selectedReptile = reptile;
        await _deleteModal.ShowAsync();
    }

    private async Task RefreshListAsync()
    {
        var name = _selectedReptile?.Name ?? "Reptile";
        Reptiles = await ReptileService.GetAllAsync();
        messages.Add(new ToastMessage
        {
            Type = ToastType.Success,
            Title = "Deleted",
            HelpText = DateTime.Now.ToShortTimeString(),
            Message = $"{name} has been permanently deleted."
        });
        StateHasChanged();
    }

    private int CalculateAge(TimeSpan span)
    {
        return (int)(span.TotalDays / 365.2425);
    }

}
